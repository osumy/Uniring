<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ثبت انگشتر جدید</title>

        <!-- Google fonts for Persian and Arabic -->
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;600;700&family=Vazirmatn:wght@300;400;600;700&display=swap"
          rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/NewRingStyle.css">

</head>
<body>
    <div class="form-container">
        <div class="progress-container">
            <div class="progress-bar" id="progressBar"></div>
            <div class="step active" id="step1">۱</div>
            <div class="step" id="step2">۲</div>
            <div class="step" id="step3">۳</div>
            <div class="step" id="step4">۴</div>
        </div>

        <!-- Scene 1: Ring Name -->
        <div class="scene active" id="scene1">
            <h1>ثبت انگشتر جدید</h1>
            <p class="subtitle">لطفاً نام انگشتر را وارد کنید</p>
            
            <div class="input-group">
                <label for="ring-name">نام انگشتر</label>
                <input type="text" 
                       id="ring-name" 
                       name="ring-name" 
                       placeholder="مثلاً: انگشتر نفیس «شکارچی»"
                       required>
            </div>
            
            <div class="btn-group">
                <button class="btn btn-next" id="next1">ادامه</button>
            </div>
        </div>

        <!-- Scene 2: Media Upload -->
        <div class="scene" id="scene2">
            <h1>آپلود مدیا</h1>
            <p class="subtitle">عکس یا ویدیوی انگشتر را آپلود کنید</p>
            
            <div class="upload-container" id="uploadContainer">
                <div class="upload-icon">
                    <i class="fas fa-cloud-upload-alt"></i>
                </div>
                <p>فایل‌ها را به اینجا بکشید و رها کنید</p>
                <p class="upload-text">یا</p>
                <button class="btn btn-next" style="width: auto;">انتخاب فایل‌ها</button>
                <input type="file" class="file-input" id="mediaUpload" accept="image/*,video/*" multiple>
            </div>
            
            <div class="file-list" id="fileList">
                <!-- Files will be added here dynamically -->
            </div>
            
            <div class="progress-container-media" id="progressContainer">
                <div class="progress-bar-media" id="progressBarMedia"></div>
                <div class="progress-percent" id="progressPercent">0%</div>
            </div>
            
            <div class="btn-group">
                <button class="btn btn-prev" id="prev2">بازگشت</button>
                <button class="btn btn-next" id="next2" disabled>ادامه</button>
            </div>
        </div>

        <!-- Scene 3: Description -->
        <div class="scene" id="scene3">
            <h1>توضیحات</h1>
            <p class="subtitle">توضیحات اختیاری در مورد انگشتر</p>
            
            <div class="input-group">
                <label for="ring-desc">توضیحات (اختیاری)</label>
                <textarea 
                    id="ring-desc" 
                    name="ring-desc" 
                    placeholder="مثلاً: فیروزه نیشابور، به سبک حکاکی سه بعدی"></textarea>
            </div>
            
            <div class="ring-preview">
                <div class="preview-image">
                    <i class="fas fa-image"></i>
                </div>
                <div class="preview-text">
                    <div class="preview-name" id="previewName">نام انگشتر</div>
                    <div class="preview-desc" id="previewDesc">بدون توضیحات</div>
                </div>
            </div>
            
            <div class="btn-group">
                <button class="btn btn-prev" id="prev3">بازگشت</button>
                <button class="btn btn-next" id="next3">بررسی و ارسال</button>
            </div>
        </div>

        <!-- Scene 4: Confirmation -->
        <div class="scene" id="scene4">
            <div class="success-icon">
                <i class="fas fa-check-circle"></i>
            </div>
            <h1>آماده ارسال هستید؟</h1>
            <p class="subtitle">قبل از ارسال، جزئیات انگشتر را بررسی کنید.</p>
            
            <div class="ring-preview">
                <div class="preview-image">
                    <i class="fas fa-diamond"></i>
                </div>
                <div class="preview-text">
                    <div class="preview-name" id="finalName">نام انگشتر</div>
                    <div class="preview-desc" id="finalDesc">بدون توضیحات</div>
                </div>
            </div>
            
            <button class="btn-submit" id="submitBtn">ارسال انگشتر</button>
        </div>
    </div>

    <script>
        const apiBaseUrl = '@ViewBag.ApiBaseUrl';

        // Form data object
        const formData = {
            name: '',
            media: [],
            description: ''
        };

        // DOM Elements
        const scenes = document.querySelectorAll('.scene');
        const steps = document.querySelectorAll('.step');
        const progressBar = document.getElementById('progressBar');
        
        // Scene navigation
        function showScene(sceneId) {
            // Hide all scenes
            scenes.forEach(scene => scene.classList.remove('active'));
            
            // Show requested scene
            document.getElementById(sceneId).classList.add('active');
            
            // Update progress bar
            const sceneNumber = parseInt(sceneId.replace('scene', ''));
            progressBar.style.width = `${(sceneNumber - 1) * 33.33}%`;
            
            // Update step indicators
            steps.forEach((step, index) => {
                step.classList.remove('active', 'completed');
                if (index < sceneNumber - 1) {
                    step.classList.add('completed');
                } else if (index === sceneNumber - 1) {
                    step.classList.add('active');
                }
            });
        }

        // Scene 1: Ring Name
        document.getElementById('next1').addEventListener('click', () => {
            const name = document.getElementById('ring-name').value.trim();
            if (name) {
                formData.name = name;
                showScene('scene2');
                document.getElementById('previewName').textContent = name;
                document.getElementById('finalName').textContent = name;
            } else {
                alert('لطفاً نام انگشتر را وارد کنید');
            }
        });

        // Scene 2: Media Upload
        const uploadContainer = document.getElementById('uploadContainer');
        const fileInput = document.getElementById('mediaUpload');
        const fileList = document.getElementById('fileList');
        const next2Btn = document.getElementById('next2');

        // Click on upload container triggers file input
        uploadContainer.addEventListener('click', () => {
            fileInput.click();
        });

        // Utility to format bytes
        function formatBytes(bytes) {
            if (!bytes && bytes !== 0) return '';
            const sizes = ['بایت', 'کیلوبایت', 'مگابایت', 'گیگابایت'];
            if (bytes === 0) return '0 بایت';
            const i = Math.floor(Math.log(bytes) / Math.log(1024));
            const val = bytes / Math.pow(1024, i);
            return `${val.toFixed(1)} ${sizes[i]}`;
        }

        let localMediaCounter = 0;

        function addFiles(files) {
            if (!files || !files.length) return;

            Array.from(files).forEach(file => {
                const ext = file.name.split('.').pop()?.toLowerCase() || '';
                const isVideo = ['mp4', 'webm', 'mov', 'mkv'].includes(ext);
                const maxVideoBytes = 100 * 1024 * 1024;

                if (!['jpg', 'jpeg', 'png', 'gif', 'webp', 'mp4', 'webm', 'mov', 'mkv'].includes(ext)) {
                    alert(`فرمت فایل "${file.name}" پشتیبانی نمی‌شود.`);
                    return;
                }

                if (isVideo && file.size > maxVideoBytes) {
                    alert(`حجم ویدیو "${file.name}" بیشتر از ۱۰۰ مگابایت است.`);
                    return;
                }

                const localId = `m_${++localMediaCounter}`;

                const mediaItem = {
                    localId,
                    file,
                    isVideo,
                    uploaded: false,
                    mediaId: null
                };
                formData.media.push(mediaItem);

                const fileItem = document.createElement('div');
                fileItem.className = 'file-item';
                fileItem.dataset.localId = localId;
                fileItem.innerHTML = `
                    <div class="file-main">
                        <span class="file-name">${file.name}</span>
                        <span class="file-meta">${isVideo ? 'ویدیو' : 'عکس'} • ${formatBytes(file.size)}</span>
                    </div>
                    <div class="file-actions">
                        <button type="button" class="file-move-up">↑</button>
                        <button type="button" class="file-move-down">↓</button>
                        <button type="button" class="file-remove">حذف</button>
                    </div>
                    <div class="file-progress">
                        <div class="file-progress-bar"></div>
                    </div>
                `;
                fileList.appendChild(fileItem);

                const removeBtn = fileItem.querySelector('.file-remove');
                const moveUpBtn = fileItem.querySelector('.file-move-up');
                const moveDownBtn = fileItem.querySelector('.file-move-down');

                removeBtn.addEventListener('click', () => {
                    formData.media = formData.media.filter(m => m.localId !== localId);
                    fileItem.remove();
                    if (formData.media.length === 0) {
                        next2Btn.disabled = true;
                    }
                });

                moveUpBtn.addEventListener('click', () => {
                    const index = formData.media.findIndex(m => m.localId === localId);
                    if (index > 0) {
                        const tmp = formData.media[index - 1];
                        formData.media[index - 1] = formData.media[index];
                        formData.media[index] = tmp;
                        fileList.insertBefore(fileItem, fileItem.previousElementSibling);
                    }
                });

                moveDownBtn.addEventListener('click', () => {
                    const index = formData.media.findIndex(m => m.localId === localId);
                    if (index < formData.media.length - 1) {
                        const tmp = formData.media[index + 1];
                        formData.media[index + 1] = formData.media[index];
                        formData.media[index] = tmp;
                        const next = fileItem.nextElementSibling;
                        if (next) {
                            fileList.insertBefore(next, fileItem);
                        }
                    }
                });
            });

            if (formData.media.length > 0) {
                next2Btn.disabled = false;
            }
        }

        // Handle file selection
        fileInput.addEventListener('change', (e) => {
            const files = e.target.files;
            if (files.length > 0) {
                addFiles(files);
                // reset input so selecting same files again still triggers change
                fileInput.value = '';
            }
        });

        // Drag and drop functionality
        uploadContainer.addEventListener('dragover', (e) => {
            e.preventDefault();
            uploadContainer.style.backgroundColor = '#e0e6ff';
        });

        uploadContainer.addEventListener('dragleave', () => {
            uploadContainer.style.backgroundColor = '#f8f9ff';
        });

        uploadContainer.addEventListener('drop', (e) => {
            e.preventDefault();
            uploadContainer.style.backgroundColor = '#f8f9ff';
            const files = e.dataTransfer.files;
            if (files.length > 0) {
                addFiles(files);
            }
        });

        document.getElementById('next2').addEventListener('click', () => {
            if (formData.media.length > 0) {
                showScene('scene3');
            }
        });

        document.getElementById('prev2').addEventListener('click', () => {
            showScene('scene1');
        });

        // Scene 3: Description
        const ringDesc = document.getElementById('ring-desc');
        ringDesc.addEventListener('input', () => {
            formData.description = ringDesc.value;
            document.getElementById('previewDesc').textContent = 
                ringDesc.value || 'بدون توضیحات';
            document.getElementById('finalDesc').textContent = 
                ringDesc.value || 'بدون توضیحات';
        });

        document.getElementById('next3').addEventListener('click', () => {
            showScene('scene4');
        });

        document.getElementById('prev3').addEventListener('click', () => {
            showScene('scene2');
        });

        async function uploadSingleMedia(mediaItem) {
            return new Promise((resolve, reject) => {
                if (!apiBaseUrl) {
                    reject(new Error('Api base url is not configured.'));
                    return;
                }

                const file = mediaItem.file;
                const xhr = new XMLHttpRequest();
                xhr.open('POST', apiBaseUrl + 'Media/upload', true);

                const form = new FormData();
                form.append('file', file);

                const rowEl = fileList.querySelector(`.file-item[data-local-id="${mediaItem.localId}"]`);
                const progressBarEl = rowEl?.querySelector('.file-progress-bar');

                xhr.upload.onprogress = (event) => {
                    if (!progressBarEl || !event.lengthComputable) return;
                    const percent = (event.loaded / event.total) * 100;
                    progressBarEl.style.width = `${percent}%`;
                };

                xhr.onreadystatechange = () => {
                    if (xhr.readyState === XMLHttpRequest.DONE) {
                        if (xhr.status >= 200 && xhr.status < 300) {
                            try {
                                const res = JSON.parse(xhr.responseText);
                                mediaItem.uploaded = true;
                                mediaItem.mediaId = res.id || res.Id || res.id?.id || null;
                                if (progressBarEl) progressBarEl.style.width = '100%';
                                resolve(mediaItem);
                            } catch (e) {
                                reject(e);
                            }
                        } else {
                            reject(new Error(`Upload failed with status ${xhr.status}`));
                        }
                    }
                };

                xhr.onerror = () => reject(new Error('Network error during upload.'));

                xhr.send(form);
            });
        }

        async function registerRingOnServer() {
            if (!apiBaseUrl) throw new Error('Api base url is not configured.');

            const mediaIds = formData.media
                .filter(m => m.uploaded && m.mediaId)
                .map(m => m.mediaId);

            const payload = {
                Name: formData.name,
                Description: formData.description || null,
                OwnerPhoneNumber: null,
                MediaIds: mediaIds
            };

            const res = await fetch(apiBaseUrl + 'Admin/rings', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(payload)
            });

            if (!res.ok) {
                throw new Error('ثبت انگشتر در سرور ناموفق بود.');
            }
        }

        // Scene 4: Confirmation
        document.getElementById('submitBtn').addEventListener('click', async () => {
            if (!formData.name) {
                alert('نام انگشتر مشخص نیست.');
                showScene('scene1');
                return;
            }
            if (!formData.media.length) {
                alert('حداقل یک مدیا برای انگشتر انتخاب کنید.');
                showScene('scene2');
                return;
            }

            try {
                for (const mediaItem of formData.media) {
                    if (!mediaItem.uploaded) {
                        await uploadSingleMedia(mediaItem);
                    }
                }

                await registerRingOnServer();

                alert(`انگشتر "${formData.name}" با موفقیت ثبت شد!`);

                // Reset form
                formData.name = '';
                formData.media = [];
                formData.description = '';
                document.getElementById('ring-name').value = '';
                document.getElementById('ring-desc').value = '';
                fileList.innerHTML = '';
                next2Btn.disabled = true;
                document.getElementById('previewName').textContent = 'نام انگشتر';
                document.getElementById('previewDesc').textContent = 'بدون توضیحات';
                document.getElementById('finalName').textContent = 'نام انگشتر';
                document.getElementById('finalDesc').textContent = 'بدون توضیحات';

                showScene('scene1');
            } catch (err) {
                console.error('Error registering ring with media:', err);
                alert('خطا در آپلود مدیا یا ثبت انگشتر. لطفاً دوباره تلاش کنید.');
            }
        });
    </script>
</body>
</html>