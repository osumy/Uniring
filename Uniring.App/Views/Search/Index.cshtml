<!doctype html>
<html lang="fa" dir="rtl">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>انگشتر شریعتی</title>

    <!-- Google fonts for Persian and Arabic -->
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;600;700&family=Vazirmatn:wght@300;400;600;700&display=swap"
          rel="stylesheet">

    <link href="~/css/SearchPageStyle.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>

<body>
    <div class="lang-switch" aria-hidden="false" role="toolbar" aria-label="language switch">
        <div class="lang-group-right">
            <button class="lang-btn active" data-lang="fa">فارسی</button>
            <button class="lang-btn" data-lang="ar">العربية</button>
        </div>

        <div class="login-group-left">
            <a href="/login"><button class="login-btn">ورود</button></a>
        </div>
    </div>

    <main class="page" id="page">
        <div class="logo-circle" aria-hidden="true">
            <!-- magnifier icon -->
            <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0016 9.5 6.5 6.5 0 109.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zM10 15a5 5 0 110-10 5 5 0 010 10z" />
            </svg>
        </div>

        <h1 id="title">تأیید اصالت انگشتر</h1>
        <p class="lead" id="subtitle">شماره سریال یا شناسه یکتا (Uid) انگشتر خود را وارد کنید تا اصالت آن را بررسی کنید</p>

        <section class="card" role="region" aria-labelledby="lookup-label">
            <div class="badge">
                <span class="crown" aria-hidden="true">♛</span>
                <span id="lookup-label">جستجوی شماره سریال یا Uid</span>
            </div>

            <form id="searchForm" class="search-row" aria-label="identifier lookup form">
                <input id="serial" class="input" type="text" inputmode="text" autocomplete="off"
                       placeholder="مثلاً: SH-26227-8fXe یا 8fXe"
                       aria-label="ring identifier input">

                <button class="btn" type="submit" aria-label="جستجو">
                    <!-- search icon -->
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0016 9.5 6.5 6.5 0 109.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5z" />
                    </svg>
                    <span id="btn-text">جستجو</span>
                </button>
            </form>
            <script>
                document.getElementById('searchForm').addEventListener('submit', function(e) {
                    e.preventDefault();
                    const identifier = document.getElementById('serial').value;
                    window.location.href = '/' + encodeURIComponent(identifier);
                });
            </script>

            <p class="help" id="help">در یافتن انگشتر خود مشکل دارید؟ برای کمک با تیم پشتیبانی تماس بگیرید.</p>
        </section>
    </main>
    <!-- Result: Not Found -->
    <section id="result-notfound" class="card" style="display:none;" aria-live="polite">
        <div class="badge">
            <span class="crown" aria-hidden="true">⚠</span>
            <span id="nf-title">یافت نشد</span>
        </div>

        <p id="nf-message" class="lead" style="margin-bottom:22px;">
            شماره سریال مورد نظر در سیستم ما پیدا نشد. لطفا دوباره بررسی کنید یا با پشتیبانی تماس بگیرید.
        </p>

        <div style="display:flex;gap:12px;justify-content:center;">
            <button class="btn" onclick="hideResults(); document.querySelector('section.card').style.display = 'block'; document.getElementById('serial').value = ''; document.getElementById('serial').focus();">
                <!-- back / try again -->
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M10 19l-7-7 7-7v14zM14 5v14h2V5h-2z" /></svg>
                <span id="nf-btn">تلاش مجدد</span>
            </button>
        </div>
    </section>

    <!-- Result: Product Found -->
    <section id="result-product" class="card" style="display:none;" aria-live="polite">
        <div class="card-content">
            <div style="margin-top:95px;"></div>
        <div class="badge">
            <span class="crown" aria-hidden="true">💍</span>
            <span id="prod-title">اطلاعات انگشتر</span>
        </div>

        <div class="product-grid" style="gap:22px;align-items:center;margin-top:6px;">
            <div class="prod-image-wrap">
                <div id="mediaCarousel" class="media-carousel">
                    <!-- Media items will be loaded here -->
                </div>
                <button class="carousel-btn prev" id="carouselPrev"><i class="fas fa-chevron-right"></i></button>
                <button class="carousel-btn next" id="carouselNext"><i class="fas fa-chevron-left"></i></button>
            </div>

            <div class="prod-info">
                <h2 id="prod-name" style="margin:0 0 8px;font-size:26px;"></h2>
                <p id="prod-desc" style="color:var(--muted);margin:0 0 12px;"></p>

                <dl style="text-align:right;margin:12px 0;color:var(--muted);">
                    <dt id="prod-dt-serial" style="font-weight:700;">شماره سریال</dt>
                    <dd id="prod-serial" style="margin:6px 0 10px;"></dd>
                </dl>

                <p id="prod-verify" style="margin-top:12px;color:#cbe6d9;font-weight:700;">
                    اصالت این انگشتر توسط فروشگاه تایید می شود.
                </p>

                <div id="login-prompt" style="display:none; margin-top: 15px; padding: 15px; background: rgba(255,255,255,0.05); border-radius: 8px; text-align: center; border: 1px dashed var(--accent);">
                    <p id="login-text" style="color: var(--white); font-weight: 600; margin-bottom: 10px;">جهت بررسی مالکیت انگشتر ابتدا وارد سایت شوید.</p>
                    <a href="/">
                        <button class="btn" onclick="window.location.href = document.documentElement.getAttribute('lang') === 'ar' ? '/Account/LoginAr' : '/Account/Login';">
                            <!-- login icon -->
                            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" /></svg>
                            <span id="prod-btn">ورود به سایت</span>
                        </button>
                    </a>
                </div>

                <div style="margin-top:18px;">
                    <a href="/">
                        <button class="btn">
                            <span id="rtn-btn">بازگشت</span>
                        </button>
                    </a>
                </div>
            </div>
        </div>
        </div>
    </section>

    <script type="text/javascript" src="~/js/SearchPageScript.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const initialRing = @Html.Raw(Json.Serialize(ViewBag.Ring));
            const isLoggedIn = document.cookie.split(';').some((item) => item.trim().startsWith('authToken=')); // Placeholder check

            if (initialRing) {
                renderProduct(initialRing, isLoggedIn);
            }
        });
    </script>
</body>
</html>