@model Uniring.Contracts.Ring.RingResponse

@{
    ViewData["Title"] = $"اطلاعات انگشتر - {Model.Serial}";
}

<!doctype html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>@ViewData["Title"] - انگشتر شریعتی</title>
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;600;700&family=Vazirmatn:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link href="~/css/SearchPageStyle.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        /* استایل‌های اختصاصی برای رفع مشکلات چیدمان */
        .product-grid {
            display: flex;
            flex-direction: column;
            align-items: center; /* وسط‌چین کردن عمودی محتوا */
            gap: 22px;
            margin-top: 6px;
        }

        @@media (min-width: 768px) {
            .product-grid {
                flex-direction: row; /* در دسکتاپ کنار هم */
                justify-content: center; /* وسط‌چین کردن افقی محتوا */
            }
        }

        .prod-image-wrap {
            position: relative;
            width: 100%;
            max-width: 400px;
            height: 300px;
            overflow: hidden;
            border-radius: 8px;
            background: #000;
        }

        .media-carousel {
            display: flex;
            height: 100%;
            transition: transform 0.3s ease-in-out;
        }

        .media-item {
            flex: 0 0 100%;
            width: 100%;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100%;
        }

            .media-item img {
                max-width: 100%;
                max-height: 100%;
                object-fit: contain;
            }

        .prod-info {
            text-align: right;
            direction: rtl;
            width: 100%;
            max-width: 400px;
        }

        /* استایل دکمه‌های کاروسل */
        .carousel-btn {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            background: rgba(0,0,0,0.5);
            color: white;
            border: none;
            padding: 10px;
            cursor: pointer;
            border-radius: 50%;
            z-index: 10;
        }

            .carousel-btn.prev {
                left: 10px;
            }

            .carousel-btn.next {
                right: 10px;
            }
    </style>
</head>
<body>
    <div class="lang-switch" aria-hidden="false" role="toolbar" aria-label="language switch">
        <div class="lang-group-right">
            <button class="lang-btn active" data-lang="fa">فارسی</button>
            <button class="lang-btn" data-lang="ar">العربية</button>
        </div>
        <div class="login-group-left">
            <a href="/login"><button class="login-btn">ورود</button></a>
        </div>
    </div>

    <main class="page" id="page">
        <div class="logo-circle" aria-hidden="true">
            <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0016 9.5 6.5 6.5 0 109.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zM10 15a5 5 0 110-10 5 5 0 010 10z" />
            </svg>
        </div>

        <h1 id="title">اطلاعات انگشتر</h1>
        <p class="lead" id="subtitle">اطلاعات اصالت و مالکیت انگشتر</p>

        <section id="result-product" class="card" aria-live="polite">
            <div class="card-content">
                <div class="badge">
                    <span class="crown" aria-hidden="true">💍</span>
                    <span>اطلاعات انگشتر</span>
                </div>

                <div class="product-grid">

                    <div class="prod-image-wrap">
                        <div id="mediaCarousel" class="media-carousel">
                            @if (Model.MediaIds != null && Model.MediaIds.Any())
                            {
                                foreach (var mediaId in Model.MediaIds)
                                {
                                    <div class="media-item">
                                        <img src="http://127.0.0.1:5001/api/Media/download/@mediaId" alt="Ring Image">
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="media-item">
                                    <img src="https://via.placeholder.com/400x300.png?text=No+Image" alt="No Image">
                                </div>
                            }
                        </div>

                        @if (Model.MediaIds != null && Model.MediaIds.Count > 1)
                        {
                            <button class="carousel-btn prev" onclick="changeMedia(-1)"><i class="fas fa-chevron-right"></i></button>
                            <button class="carousel-btn next" onclick="changeMedia(1)"><i class="fas fa-chevron-left"></i></button>
                        }
                    </div>

                    <div class="prod-info">
                        <h2 style="margin:0 0 8px;font-size:26px; color:white;">@Model.Name</h2>
                        <p style="color:#b3b3b3;margin:0 0 12px;">@Model.Description</p>

                        <dl style="text-align:right;margin:12px 0;color:#b3b3b3;">
                            <dt style="font-weight:700; color:white;">شماره سریال</dt>
                            <dd style="margin:6px 0 10px; font-family: monospace;">@Model.Serial</dd>
                        </dl>

                        <p style="margin-top:12px;color:#cbe6d9;font-weight:700;">
                            اصالت این انگشتر توسط فروشگاه تایید می شود.
                        </p>

                        <div style="margin-top:18px;">
                            <a href="/">
                                <button class="btn">
                                    <span>بازگشت</span>
                                </button>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <script>
        // جاوااسکریپت برای سوئیچ بین مدیاها
        let currentMediaIndex = 0;
        const mediaItems = document.querySelectorAll('.media-item');
        const carousel = document.getElementById('mediaCarousel');

        function changeMedia(direction) {
            if (mediaItems.length === 0) return;

            currentMediaIndex = (currentMediaIndex + direction + mediaItems.length) % mediaItems.length;

            // در حالت RTL، transform باید مثبت باشد تا به چپ برود (اگر css بر اساس rtl است)
            // اما چون flex است، -100% معمولا کار می‌کند. اگر کار نکرد، 100% را تست کنید.
            carousel.style.transform = `translateX(${-currentMediaIndex * 100}%)`;
        }
    </script>
</body>
</html>